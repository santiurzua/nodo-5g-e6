# ─────────────────────────────────────────────────────────────────────────────
# VitiScience dashboard stack: environment configuration
# Copy this file to ".env" (same folder) and adjust before `docker compose up`.
#   Windows PowerShell:  Copy-Item .env.example .env
# The .env file is read automatically by docker compose. Never commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- InfluxDB (time-series database / 2-3 day historical buffer) --------------
INFLUXDB_ORG=vitiscience
INFLUXDB_BUCKET=telemetry
# Retention of the historical buffer. Examples: 3d, 72h, 7d.
INFLUXDB_RETENTION=3d
# First-run admin user (web UI at http://localhost:8086).
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme-admin-pass
# All-access token shared by Telegraf (write) and Grafana (read).
# For the prototype a single token is fine; rotate/split for production.
INFLUXDB_TOKEN=changeme-supersecret-token

# --- Grafana (dashboard UI at http://localhost:3000) --------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme-grafana-pass

# --- MQTT broker (Mosquitto) --------------------------------------------------
# Port exposed on the host. Publishers (simulator / real gateway) connect here.
MQTT_TCP_PORT=1883
